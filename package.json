{
  "name": "@isbl/publisher",
  "version": "0.8.5",
  "description": "Simplifies creating git(lab|hub) releases and publishes to npm",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeWitchBella/isbl-publisher.git"
  },
  "author": "Isabella Skořepová <isabella@skorepova.info>",
  "license": "MIT",
  "private": false,
  "files": [
    "dist",
    "index.js"
  ],
  "bin": {
    "isbl-publisher": "./index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/publisher.d.mts",
      "default": "./dist/publisher.mjs"
    }
  },
  "types": "dist/publisher.d.mts",
  "type": "module",
  "scripts": {
    "build": "tsdown src/publisher.ts --format esm --platform node --dts",
    "prepublishOnly": "pnpm build && ./index.js prepublishOnly",
    "publish:npm": "pnpm build && ./index.js publish",
    "publish:npm:nobuild": "./index.js publish",
    "lint": "eslint src",
    "test": "echo $HOME"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "open": "^11.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  }
}
